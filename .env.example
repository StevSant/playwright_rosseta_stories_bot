# ──────────────────────────────────────────────────────────────────────────
# Rosetta Stone Bot — environment template
#
# Copy to `.env` (or `.env_<user>`) and fill in real values:
#   cp .env.example .env
# Run with:  uv run main.py            (uses .env)
#            uv run main.py .env_user   (uses a specific file)
#
# Only ROSETTA_EMAIL and ROSETTA_PASSWORD are required; every other variable
# has a sensible default and can be omitted.
# ──────────────────────────────────────────────────────────────────────────

# ── Credentials (required) ─────────────────────────────────────────────────
ROSETTA_EMAIL=your_email@example.com
ROSETTA_PASSWORD=your_password

# ── Goal ────────────────────────────────────────────────────────────────────
# Total Stories hours to accumulate (shared across all parallel sessions).
TARGET_HOURS=35

# ── Fast path (rosetta_bot/fast) ──────────────────────────────────────────────
# Number of parallel browser sessions that credit hours via the app_usage API.
PARALLEL_SESSIONS=5
# Each session reports usage in random chunks between MIN and MAX seconds.
REPORT_CHUNK_MIN_SEC=300
REPORT_CHUNK_MAX_SEC=900
# Delay between successive report POSTs per session (seconds).
REPORT_DELAY_SEC=0.5
# Language code reported to the Stories usage API.
STORIES_LANGUAGE=ENG

# ── Fallback (orchestrator) ───────────────────────────────────────────────────
# If the fast path credits fewer hours than this, the full browser bot runs.
FALLBACK_MIN_HOURS=0.1
# Which bot workflow runs as fallback: "stories" or "lesson".
FALLBACK_MODE=stories

# ── Browser bot (rosetta_bot, used by the fallback) ──────────────────────────
# Headless mode: 1 = yes, 0 = no.
BROWSER_HEADLESS=1
# Playwright slow-motion delay in ms (helps debugging when not headless).
BROWSER_SLOW_MO=500
# Enable debug screenshots / dumps: 1 = yes, 0 = no.
DEBUG=1
# Target lesson for the "lesson" fallback mode (regex, "English|Spanish").
LESSON_NAME=A Visit to Hollywood|Una visita a Hollywood
