# ──────────────────────────────────────────────────────────────────────────
# Rosetta Stone Bot — environment template
#
# Copy to `.env` (or `.env_<user>`) and fill in real values:
#   cp .env.example .env
# Run with:  uv run main.py            (uses .env)
#            uv run main.py .env_user   (uses a specific file)
#
# Only ROSETTA_EMAIL and ROSETTA_PASSWORD are required; every other variable
# has a sensible default and can be omitted.
#
# ── Accumulation design ──────────────────────────────────────────────────────
# By DEFAULT the bot is uncapped: a single run credits the entire remaining
# TARGET_HOURS at once.  Progress is persisted to a per-account JSON state file,
# so once cumulative state reaches TARGET_HOURS the bot exits immediately on
# every subsequent run.
#
# To make it behave like a real learner instead, set SESSION_HOURS_MIN/MAX and
# MAX_HOURS_PER_DAY (below) and invoke once or twice a day via Windows Task
# Scheduler.  Each run then credits only a small, randomized slice.
#
# MULTI-ACCOUNT NOTE: Give each account its own .env_<user> file with slightly
# different SESSION_HOURS_MIN/MAX, MAX_HOURS_PER_DAY, and TARGET_HOURS values,
# and schedule them at different times (e.g. every 8h offset by 1h per
# account).  This ensures their usage patterns diverge naturally.
# ──────────────────────────────────────────────────────────────────────────

# ── Credentials (required) ─────────────────────────────────────────────────
ROSETTA_EMAIL=your_email@example.com
ROSETTA_PASSWORD=your_password

# ── Cumulative goal ──────────────────────────────────────────────────────────
# Total Stories hours to accumulate over time across all runs.
# Once cumulative state reaches this value, all subsequent runs exit immediately.
TARGET_HOURS=35

# ── Accumulation caps (per run / per day) — OPTIONAL, default uncapped ───────
# Leave these UNSET to complete the full TARGET_HOURS in one run (the default).
# Uncomment and set BOTH session vars together to throttle per run; keep
# SESSION_HOURS_MAX <= MAX_HOURS_PER_DAY.  Typical: 0.5–2.0h per run, run once
# or twice a day → reaches 35h over ~3–5 weeks.
# SESSION_HOURS_MIN=0.5
# SESSION_HOURS_MAX=2.0
# Hard ceiling on hours credited within a single calendar day (UTC).
# Prevents over-reporting if the scheduler fires more often than expected.
# MAX_HOURS_PER_DAY=2.5

# ── State persistence ────────────────────────────────────────────────────────
# Directory where per-account JSON progress files are stored.
# Defaults to <project root>/state/  — override to an absolute path if needed.
# STATE_DIR=C:\bots\rosetta\state
# Override the account key used as the state file stem (default: ROSETTA_EMAIL).
# Useful when two env files share the same email.
# STATE_KEY=daniela_account

# ── Fast path (rosetta_bot/fast) ──────────────────────────────────────────────
# Number of parallel browser sessions that credit hours via the app_usage API.
# Keep this low (1–2) for gradual runs; high values finish too quickly.
PARALLEL_SESSIONS=2
# Each session reports usage in random chunks between MIN and MAX seconds.
REPORT_CHUNK_MIN_SEC=300
REPORT_CHUNK_MAX_SEC=900
# Jittered delay between successive report POSTs per session (seconds).
# Replaces the old fixed REPORT_DELAY_SEC — use a range to vary pacing.
REPORT_DELAY_MIN_SEC=1.5
REPORT_DELAY_MAX_SEC=6.0
# Language code reported to the Stories usage API.
STORIES_LANGUAGE=ENG

# ── Fallback (orchestrator) ───────────────────────────────────────────────────
# If the fast path credits fewer hours than this, the full browser bot runs.
FALLBACK_MIN_HOURS=0.1
# Which bot workflow runs as fallback: "stories" or "lesson".
FALLBACK_MODE=stories

# ── Browser bot (rosetta_bot, used by the fallback) ──────────────────────────
# Headless mode: 1 = yes, 0 = no.
BROWSER_HEADLESS=1
# Playwright slow-motion delay in ms (helps debugging when not headless).
BROWSER_SLOW_MO=500
# Enable debug screenshots / dumps: 1 = yes, 0 = no.
DEBUG=1
# Target lesson for the "lesson" fallback mode (regex, "English|Spanish").
LESSON_NAME=A Visit to Hollywood|Una visita a Hollywood
